# ============================================================
# 環境變數範本：複製此檔為 .env 並填入實際值
# 複製指令：cp .env.example .env
# ============================================================

# ----- 前端（Vite）會讀取 VITE_ 開頭的變數 -----
# 後端 API 網址（前端呼叫 tRPC 時使用）
VITE_API_URL=http://localhost:5000

# 選填：App 識別等
# VITE_APP_ID=


# ----- 後端（Node server）專用，勿放敏感資訊到 .env.example 並提交 -----
# 伺服器埠號
PORT=5000

# 允許的 CORS 來源（前端開發網址）
CORS_ORIGIN=http://localhost:3000

# Session / JWT 用密鑰
JWT_SECRET=your-secret-at-least-32-chars

# 資料庫（選填，未設定則用記憶體存 artwork 記錄）
# DATABASE_URL=mysql://user:password@host:3306/dbname

# OAuth / 登入（若之後接回登入再用）
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=


# ----- 生圖 API -----
# Replicate Flux（建議，使用提示詞管理）
# 到 https://replicate.com/account/api-tokens 申請
# REPLICATE_API_TOKEN=r8_...

# OpenAI DALL-E（可選）
# OPENAI_API_KEY=sk-...



# ----- Supabase（存圖 + 提示詞表） -----
# 在 Supabase Dashboard → Project Settings → API 可看到
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 選填，預設為 artwork-mockups
# SUPABASE_BUCKET=artwork-mockups
